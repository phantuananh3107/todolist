{
  "info": {
    "_postman_id": "suggest-category-api",
    "name": "Todo App - Suggest Category API",
    "description": "Test API gợi ý Category dựa vào mô tả",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "if (pm.response.code === 200) {",
              "    var jsonData = pm.response.json();",
              "    pm.environment.set('ACCESS_TOKEN', jsonData.accessToken);",
              "    pm.test('Token saved to environment', function () {",
              "        pm.expect(jsonData.accessToken).to.exist;",
              "    });",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"truong_admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/users/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "users", "login"]
        }
      },
      "response": []
    },
    {
      "name": "2. Get Categories",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{ACCESS_TOKEN}}"
